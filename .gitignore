# Dependency directories (المكتبات المحملة - وهي السبب الأساسي في الـ 10K تعديل)
node_modules/
/jspm_packages/

# Production build (مجلدات إخراج المشروع النهائي بعد البلد)
dist/
build/
out/

# Local env files (ملفات البيئة الحساسة التي تحتوي على باسورادت أو روابط الـ API المحلية)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs (ملفات سجلات الأخطاء)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor directories and files (ملفات إعدادات المحررات الخاصة بجهازك)
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Operating system files (ملفات النظام المؤقتة)
.DS_Store
Thumbs.db